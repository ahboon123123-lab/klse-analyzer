<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:id="@id/recorditem" android:background="@drawable/miage_data_kuang_normal" android:layout_width="match_parent" android:layout_height="@dimen/margin_50dp"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:padding="@dimen/dp_4" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="vertical" android:padding="@dimen/dp_4" android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0">
            <TextView android:textColor="@color/white" android:ellipsize="end" android:gravity="center" android:id="@id/record_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="股票名称" android:lines="2" />
            <TextView android:textColor="@color/white" android:gravity="center" android:id="@id/record_code" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_10" android:text="股票代码" android:singleLine="true" />
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:padding="@dimen/dp_4" android:layout_width="0.0dp" android:layout_height="match_parent" android:layout_weight="1.0">
            <TextView android:textColor="@color/white" android:gravity="center" android:id="@id/record_price" android:layout_width="match_parent" android:layout_height="0.0dp" android:text="买入价" android:singleLine="true" android:layout_weight="1.0" />
            <TextView android:textColor="@color/white" android:gravity="center" android:id="@id/record_time" android:layout_width="match_parent" android:layout_height="0.0dp" android:layout_marginTop="@dimen/dp_10" android:text="时间" android:layout_weight="1.0" />
        </LinearLayout>
        <TextView android:textColor="@color/white" android:gravity="center" android:id="@id/record_amount" android:layout_width="0.0dp" android:layout_height="match_parent" android:text="区间涨幅" android:singleLine="true" android:layout_weight="1.0" />
        <TextView android:textColor="@color/white" android:gravity="center" android:id="@id/record_accumulated" android:layout_width="10.0dp" android:layout_height="match_parent" android:text="累计收益" android:singleLine="true" android:layout_weight="1.0" />
    </LinearLayout>
</LinearLayout>
