<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:orientation="vertical" android:background="#000000" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
        <include layout="@layout/toolbar" />
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@id/index_title" android:layout_width="match_parent" android:layout_height="50.0dp">
            <TextView android:textColor="@color/white" android:gravity="center_horizontal" android:layout_width="120.0dp" android:layout_height="wrap_content" android:text="@string/quote_name" />
            <TextView android:textColor="@color/white" android:gravity="center" android:layout_width="0.0dp" android:layout_height="wrap_content" android:text="@string/mystock_dqj" android:layout_weight="1.0" />
            <TextView android:textColor="@color/white" android:gravity="center" android:layout_width="0.0dp" android:layout_height="wrap_content" android:text="@string/mystock_zdf" android:layout_weight="1.0" />
